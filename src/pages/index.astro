---
import Layout from '../layouts/Layout.astro';
import EdadGate from '../components/EdadGate.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Historia from '../components/Historia.astro';
import Bodegas from '../components/Bodegas.astro';
import Vinos from '../components/Vinos.astro';
import Origen from '../components/Origen.astro';
import Comprar from '../components/Comprar.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
import Modal from '../components/Modal.astro';
import WhatsAppFlotante from '../components/WhatsAppFlotante.astro';

import { VINOS } from '../data/vinos.js';
import { BODEGAS } from '../data/bodegas.js';
import { CONTACTO } from '../data/site.js';
---
<Layout>
  <EdadGate />
  <Header />
  <main>
    <Hero />
    <Historia />
    <Bodegas />
    <Vinos />
    <Origen />
    <Comprar />
    <Contacto />
  </main>
  <Footer />
  <Modal />
  <WhatsAppFlotante />
</Layout>

<script define:vars={{ VINOS, BODEGAS, CONTACTO }}>
  /* =========================================================
     VINOS WALCO — interactividad de cliente
     (los datos llegan inyectados desde Astro vía define:vars)
     ========================================================= */
  const waLink = (texto) =>
    `https://wa.me/${CONTACTO.whatsapp}?text=${encodeURIComponent(texto)}`;
  const nombreBodega = (id) => (BODEGAS.find((b) => b.id === id) || {}).nombre || "";

  /* ---- Gate de edad (sessionStorage) ---- */
  (function () {
    const gate = document.getElementById("edad-gate");
    if (!gate) return;
    if (location.search.indexOf("skipgate") !== -1 || sessionStorage.getItem("walco_edad") === "ok") {
      gate.remove();
    } else {
      document.body.classList.add("no-scroll");
    }
    const si = document.getElementById("edad-si");
    if (si) {
      si.addEventListener("click", () => {
        sessionStorage.setItem("walco_edad", "ok");
        gate.classList.add("is-hidden");
        document.body.classList.remove("no-scroll");
        setTimeout(() => gate.remove(), 400);
      });
    }
  })();

  /* ---- Filtros del catálogo (muestra/oculta cards, sin re-render) ---- */
  (function () {
    const cont = document.getElementById("filtros");
    const grid = document.getElementById("vinos-grid");
    if (!cont || !grid) return;
    const cards = Array.from(grid.querySelectorAll(".vino-card"));
    cont.addEventListener("click", (e) => {
      const btn = e.target.closest(".filtro");
      if (!btn) return;
      cont.querySelectorAll(".filtro").forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      const id = btn.dataset.bodega;
      cards.forEach((c) => {
        const visible = id === "todos" || c.dataset.bodega === id;
        c.classList.toggle("is-hidden", !visible);
      });
    });
  })();

  /* ---- Modal de ficha ---- */
  const modalEl = document.getElementById("modal");
  let ultimoFoco = null;
  let vinoActualId = null;

  // Lista de ids navegables: las cards visibles (respeta el filtro activo) en orden.
  function listaNavegable() {
    return Array.from(
      document.querySelectorAll("#vinos-grid .vino-card:not(.is-hidden)")
    ).map((c) => c.dataset.id);
  }

  // Avanza/retrocede como un carrusel (con wraparound).
  function navegar(dir) {
    const lista = listaNavegable();
    if (lista.length < 2) return;
    let i = lista.indexOf(vinoActualId);
    if (i === -1) i = 0;
    i = (i + dir + lista.length) % lista.length;
    abrirModal(lista[i]);
  }

  // Pre-descarga la imagen de la botella como archivo para poder adjuntarla
  // al compartir de forma nativa sin perder el "gesto de usuario" en el click.
  let archivoActual = null;
  function prefetchImagen(v) {
    archivoActual = null;
    fetch(v.img)
      .then((r) => r.blob())
      .then((b) => {
        archivoActual = new File([b], v.id + ".png", { type: b.type || "image/png" });
      })
      .catch(() => {});
  }

  // Compartir: usa la API nativa (con imagen de la botella) si existe; si no,
  // despliega el menú de redes como alternativa.
  function manejarCompartir(btn) {
    const v = VINOS.find((x) => x.id === vinoActualId);
    if (!v) return;
    const url = location.origin + location.pathname + "#vinos";
    const texto = `${v.nombre} — ${nombreBodega(v.bodega)} (${v.varietal}). Conocé este vino de Vinos Walco:`;
    const datos = { title: "Vinos Walco · " + v.nombre, text: texto, url };
    if (archivoActual && navigator.canShare && navigator.canShare({ files: [archivoActual] })) {
      navigator.share({ ...datos, files: [archivoActual] }).catch(() => {});
      return;
    }
    if (navigator.share) {
      navigator.share(datos).catch(() => {});
      return;
    }
    const menu = btn.parentElement.querySelector("[data-share-menu]");
    if (!menu) return;
    const abierto = menu.hidden;
    menu.hidden = !abierto;
    btn.setAttribute("aria-expanded", String(abierto));
  }

  function abrirModal(id) {
    const v = VINOS.find((x) => x.id === id);
    if (!v) return;
    // Guardar el foco solo al abrir (no en cada navegación del carrusel).
    if (!modalEl.classList.contains("is-open")) ultimoFoco = document.activeElement;
    vinoActualId = id;
    const filas = Object.entries(v.ficha)
      .map(([k, val]) => `<div class="ficha__fila"><dt>${k}</dt><dd>${val}</dd></div>`)
      .join("");
    // Datos para compartir en redes (enlace a la sección de vinos + descripción del vino).
    const compartirUrl = location.origin + location.pathname + "#vinos";
    const compartirTxt = `${v.nombre} — ${nombreBodega(v.bodega)} (${v.varietal}). Conocé este vino de Vinos Walco:`;
    const cu = encodeURIComponent(compartirUrl);
    const ct = encodeURIComponent(compartirTxt);
    const ctu = encodeURIComponent(compartirTxt + " " + compartirUrl);
    document.getElementById("modal-contenido").innerHTML = `
      <button class="modal__cerrar" data-close aria-label="Cerrar">&times;</button>
      <div class="modal__grid">
        <div class="modal__img">
          <button class="modal__nav modal__nav--prev" data-nav="-1" aria-label="Vino anterior">&#8249;</button>
          <img src="${v.img}" alt="${v.nombre}">
          <button class="modal__nav modal__nav--next" data-nav="1" aria-label="Vino siguiente">&#8250;</button>
        </div>
        <div class="modal__info">
          <span class="modal__bodega">${nombreBodega(v.bodega)}</span>
          <h3 class="modal__nombre">${v.nombre}</h3>
          <p class="modal__linea">${v.linea}${v.cosecha && v.cosecha !== "—" ? " · Cosecha " + v.cosecha : ""}</p>
          <p class="modal__varietal">${v.varietal}</p>
          <p class="modal__cata">${v.cata}</p>
          <dl class="ficha">${filas}</dl>
          <div class="modal__acciones">
            <a class="btn btn--wa" href="${waLink("¡Hola! Quiero consultar por el vino " + v.nombre + " (" + nombreBodega(v.bodega) + ").")}" target="_blank" rel="noopener">
              Consultar por WhatsApp
            </a>
            <div class="share">
              <button class="btn btn--share" type="button" data-share aria-haspopup="true" aria-expanded="false">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>
                Compartir
              </button>
              <div class="share__menu" data-share-menu hidden>
                <a class="share__op" href="https://www.facebook.com/sharer/sharer.php?u=${cu}" target="_blank" rel="noopener">Facebook</a>
                <a class="share__op" href="https://twitter.com/intent/tweet?url=${cu}&text=${ct}" target="_blank" rel="noopener">X (Twitter)</a>
                <a class="share__op" href="https://wa.me/?text=${ctu}" target="_blank" rel="noopener">WhatsApp</a>
                <a class="share__op" href="https://t.me/share/url?url=${cu}&text=${ct}" target="_blank" rel="noopener">Telegram</a>
                <button class="share__op" type="button" data-net="copy">Copiar enlace</button>
              </div>
            </div>
          </div>
        </div>
      </div>`;
    modalEl.classList.add("is-open");
    document.body.style.overflow = "hidden";
    modalEl.querySelector(".modal__cerrar").focus();
    prefetchImagen(v);
  }

  function cerrarModal() {
    modalEl.classList.remove("is-open");
    document.body.style.overflow = "";
    if (ultimoFoco) ultimoFoco.focus();
  }

  if (modalEl) {
    modalEl.addEventListener("click", (e) => {
      const nav = e.target.closest("[data-nav]");
      if (nav) { navegar(parseInt(nav.dataset.nav, 10)); return; }
      const share = e.target.closest("[data-share]");
      if (share) { manejarCompartir(share); return; }
      const copy = e.target.closest('[data-net="copy"]');
      if (copy) {
        const url = location.origin + location.pathname + "#vinos";
        navigator.clipboard?.writeText(url).then(() => {
          const prev = copy.textContent;
          copy.textContent = "¡Enlace copiado!";
          setTimeout(() => { copy.textContent = prev; }, 1600);
        }).catch(() => {});
        return;
      }
      if (e.target.dataset.close !== undefined) cerrarModal();
    });
    document.addEventListener("keydown", (e) => {
      if (!modalEl.classList.contains("is-open")) return;
      if (e.key === "Escape") cerrarModal();
      else if (e.key === "ArrowLeft") navegar(-1);
      else if (e.key === "ArrowRight") navegar(1);
    });
  }

  document.querySelectorAll(".vino-card").forEach((card) => {
    const open = () => abrirModal(card.dataset.id);
    card.addEventListener("click", open);
    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open();
      }
    });
  });

  /* ---- Navegación móvil + header al scrollear ---- */
  (function () {
    const toggle = document.getElementById("nav-toggle");
    const menu = document.getElementById("nav-menu");
    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        const open = menu.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", open);
      });
      menu.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          menu.classList.remove("is-open");
          toggle.setAttribute("aria-expanded", false);
        })
      );
    }
    const header = document.querySelector(".header");
    if (header) {
      window.addEventListener("scroll", () => {
        header.classList.toggle("is-scrolled", window.scrollY > 40);
      });
    }
  })();
</script>
