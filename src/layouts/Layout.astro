---
import '../styles/global.css';

const {
  title = 'Vinos Walco — Vinos de Altura del Norte Argentino',
  description = 'Vinos de altura del norte argentino. Venta directa de vinos de autor elaborados con comunidades originarias, cooperativas y fincas: Los Amaichás, Michango y María del Pilar.',
  ogImage = '/img/walco_logo.png',
} = Astro.props;

// Las redes sociales requieren URLs absolutas para la imagen y la página.
const ogImageUrl = new URL(ogImage, Astro.site).href;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Vinos Walco" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1360" />
  <meta property="og:image:height" content="840" />
  <meta property="og:image:alt" content="Logo de Vinos Walco" />
  <meta property="og:locale" content="es_AR" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon (placeholder) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍷</text></svg>" />

  <!-- Tipografías -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
