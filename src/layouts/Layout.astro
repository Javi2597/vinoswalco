---
import '../styles/global.css';

const {
  title = 'Vinos Walco — Vinos de Altura del Norte Argentino',
  description = 'Vinos de altura del norte argentino. Venta directa de vinos de autor elaborados con comunidades originarias, cooperativas y fincas: Los Amaichás, Michango y María del Pilar.',
  ogImage = '/img/botellas/mariadelpilar-01-enraizado-bottle.png',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Vinos Walco — Vinos de Altura" />
  <meta property="og:description" content="Vinos de autor del norte argentino. Venta directa, sin intermediarios." />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_AR" />

  <!-- Favicon (placeholder) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍷</text></svg>" />

  <!-- Tipografías -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
