---
/**
 * BackgroundAnimation — fondo del Hero.
 *
 * Renderiza un poster estático (imagen de respaldo) y, si se pasa `src`,
 * un <video> de fondo con carga diferida. El video sólo se carga cuando
 * el bloque es visible y nunca en mobile / prefers-reduced-motion / save-data,
 * para no penalizar el LCP. Sobre todo se aplica un overlay oscuro para que
 * el texto del Hero quede legible.
 *
 * Props:
 *   poster  (req) ruta de la imagen de respaldo (también poster del video).
 *   src     (opt) ruta del video .mp4/.webm. Si no se pasa, queda solo el poster.
 *   overlay (opt) opacidad del overlay oscuro (0-1). Default 0.6.
 */
interface Props {
  poster: string;
  src?: string;
  overlay?: number;
}
const { poster, src, overlay = 0.6 } = Astro.props;
---
<div class="bg-anim" data-bg-anim>
  <img
    class="bg-anim__poster"
    src={poster}
    alt=""
    aria-hidden="true"
    fetchpriority="low"
    decoding="async"
  />
  {src && (
    <video
      class="bg-anim__video"
      data-bg-video
      data-src={src}
      poster={poster}
      autoplay
      muted
      loop
      playsinline
      preload="none"
      aria-hidden="true"
      tabindex="-1"
    ></video>
  )}
  <div class="bg-anim__overlay" style={`opacity:${overlay}`}></div>
</div>

<style>
  .bg-anim {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  .bg-anim__poster,
  .bg-anim__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* El video aparece con un fundido una vez que cargó, sobre el poster. */
  .bg-anim__video {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .bg-anim__video.is-ready {
    opacity: 1;
  }
  /* Overlay oscuro borravino/negro para legibilidad del texto. */
  .bg-anim__overlay {
    position: absolute;
    inset: 0;
    background: #0c0709;
  }
</style>

<script>
  // Carga diferida del video de fondo. No corre si no hay <video> (solo poster).
  (function () {
    const root = document.querySelector<HTMLElement>('[data-bg-anim]');
    const video = root?.querySelector<HTMLVideoElement>('[data-bg-video]');
    if (!root || !video) return;

    // En mobile, con movimiento reducido o ahorro de datos: solo el poster.
    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isSmall = matchMedia('(max-width: 760px)').matches;
    const saveData = (navigator as any).connection?.saveData === true;
    if (reduceMotion || isSmall || saveData) return;

    const cargar = () => {
      const url = video.dataset.src;
      if (!url) return;
      video.src = url;
      video.load();
      video.addEventListener(
        'loadeddata',
        () => video.classList.add('is-ready'),
        { once: true }
      );
      const p = video.play();
      if (p && typeof p.catch === 'function') p.catch(() => {});
    };

    // Carga sólo cuando el Hero entra en viewport (no bloquea el LCP inicial).
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries, obs) => {
          if (entries.some((e) => e.isIntersecting)) {
            cargar();
            obs.disconnect();
          }
        },
        { rootMargin: '200px' }
      );
      io.observe(root);
    } else {
      cargar();
    }
  })();
</script>
