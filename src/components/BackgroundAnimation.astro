---
/**
 * BackgroundAnimation — fondo del Hero.
 *
 * Renderiza un poster estático (imagen de respaldo) y, si se pasa `src`,
 * un <video> de fondo con carga diferida. El video sólo se carga cuando
 * el bloque es visible y nunca en mobile / prefers-reduced-motion / save-data,
 * para no penalizar el LCP. Sobre todo se aplica un overlay oscuro para que
 * el texto del Hero quede legible.
 *
 * Props:
 *   poster  (req) ruta de la imagen de respaldo (también poster del video).
 *   src     (opt) ruta del video .mp4 (respaldo). Si no se pasa, queda solo el poster.
 *   srcWebm  (opt) ruta del video .webm (más liviano, se prioriza si existe).
 *   overlay  (opt) opacidad del overlay oscuro (0-1). Default 0.6.
 *   priority (opt) si el bloque está arriba del pliegue (p. ej. el Hero), carga
 *            el poster de inmediato para evitar un parpadeo oscuro en el primer
 *            pintado. Default false (carga diferida, ideal bajo el pliegue).
 */
interface Props {
  poster: string;
  alt?: string;
  src?: string;
  srcWebm?: string;
  overlay?: number;
  priority?: boolean;
}
const { poster, alt = '', src, srcWebm, overlay = 0.6, priority = false } = Astro.props;
const hasVideo = Boolean(src || srcWebm);
---
<div class="bg-anim" data-bg-anim>
  <div class="bg-anim__inner">
    <img
      class="bg-anim__poster"
      src={poster}
      alt={alt}
      aria-hidden="true"
      fetchpriority={priority ? 'high' : 'low'}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
    />
    {hasVideo && (
      <video
        class="bg-anim__video"
        data-bg-video
        data-src={src}
        data-src-webm={srcWebm}
        poster={poster}
        autoplay
        muted
        loop
        playsinline
        preload="none"
        aria-hidden="true"
        tabindex="-1"
      ></video>
    )}
    <div class="bg-anim__overlay" style={`opacity:${overlay}`}></div>
  </div>
</div>

<style>
  .bg-anim {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    /* Respaldo vinoso: evita un parpadeo negro en los bordes antes de que
       el poster/video pinten en el primer render. */
    background: #1a0f12;
  }
  /* Envoltorio que contiene poster + video + overlay. Por defecto llena todo
     el bloque; en mobile se puede fijar al alto de pantalla (ver global.css)
     para que el video no quede demasiado ampliado en secciones muy altas. */
  .bg-anim__inner {
    position: absolute;
    inset: 0;
  }
  .bg-anim__poster,
  .bg-anim__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* El video aparece con un fundido una vez que cargó, sobre el poster. */
  .bg-anim__video {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  .bg-anim__video.is-ready {
    opacity: 1;
  }
  /* Overlay oscuro borravino/negro para legibilidad del texto. */
  .bg-anim__overlay {
    position: absolute;
    inset: 0;
    background: #0c0709;
  }
</style>

<script>
  // Carga diferida del/los video(s) de fondo. Soporta varias instancias en la
  // misma página (p. ej. Hero + sección Vinos).
  (function () {
    // Con movimiento reducido o ahorro de datos: solo el poster.
    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as any).connection?.saveData === true;
    if (reduceMotion || saveData) return;

    const roots = document.querySelectorAll<HTMLElement>('[data-bg-anim]');

    roots.forEach((root) => {
      const video = root.querySelector<HTMLVideoElement>('[data-bg-video]');
      if (!video) return;

      const cargar = () => {
        const mp4 = video.dataset.src;
        const webm = video.dataset.srcWebm;
        if (!mp4 && !webm) return;
        // Se prioriza WebM (más liviano); el navegador elige el primer formato
        // que soporta. Se inyectan como <source> para mantener la carga diferida.
        const fuentes: Array<[string, string]> = [];
        if (webm) fuentes.push([webm, 'video/webm']);
        if (mp4) fuentes.push([mp4, 'video/mp4']);
        for (const [url, type] of fuentes) {
          const s = document.createElement('source');
          s.src = url;
          s.type = type;
          video.appendChild(s);
        }
        video.load();
        video.addEventListener(
          'loadeddata',
          () => video.classList.add('is-ready'),
          { once: true }
        );
        const p = video.play();
        if (p && typeof p.catch === 'function') p.catch(() => {});
      };

      // Carga sólo cuando el bloque entra en viewport (no bloquea el LCP inicial).
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            if (entries.some((e) => e.isIntersecting)) {
              cargar();
              obs.disconnect();
            }
          },
          { rootMargin: '200px' }
        );
        io.observe(root);
      } else {
        cargar();
      }
    });
  })();
</script>
