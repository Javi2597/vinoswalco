---
// 1 · HERO
import BackgroundAnimation from './BackgroundAnimation.astro';
---
<section class="hero" id="inicio">
  <BackgroundAnimation
    poster="/img/hero-poster.jpg"
    src="/vid/vinedo-fondo.mp4"
    srcWebm="/vid/vinedo-fondo.webm"
    priority
  />
  <div class="container hero__content">
    <p class="hero__kicker">Norte argentino · Vinos de autor</p>
    <h1 class="hero__title">Vinos de altura,<br>de la cepa a tu copa</h1>
    <p class="hero__sub">Trabajamos junto a comunidades originarias, cooperativas y fincas para llevar a tu mesa vinos de sabores únicos y originarios, sin intermediarios.</p>
    <div class="hero__btns">
      <a href="#vinos" class="btn">Conocé los vinos</a>
      <a href="#historia" class="btn btn--ghost">Nuestra historia</a>
    </div>
  </div>
  <div class="hero__scroll">↓</div>
</section>
